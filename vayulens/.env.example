# Copy to .env and fill in. Empty values => that adapter logs a warning and skips gracefully.

# OpenAQ v3 ground-sensor API. Free key: https://explore.openaq.org/register
OPENAQ_API_KEY=

# NASA FIRMS active-fire MAP_KEY. Free: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=

# Anthropic (optional, for natural-language attribution summaries). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional overrides (sensible defaults live in backend/config.py) ---
# VAYULENS_DB_PATH=data/vayulens.duckdb
# FIRMS_SOURCE=VIIRS_SNPP_NRT
# OPENAQ_BASE_URL=https://api.openaq.org/v3
