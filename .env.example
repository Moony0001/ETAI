# Copy to .env and fill in. Empty values => that adapter logs a warning and skips gracefully.

# OpenAQ v3 ground-sensor API. Free key: https://explore.openaq.org/register
OPENAQ_API_KEY=

# NASA FIRMS active-fire MAP_KEY. Free: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=

# --- LLM narration (optional) -------------------------------------------------
# Explains the engine's numbers in plain language + EN/Hindi advisory. Provider is
# swappable; any failure or missing key degrades to deterministic text. "none"
# forces the fallback. Default provider is Gemini (free, no credit card).
NARRATION_PROVIDER=gemini          # gemini | groq | anthropic | bedrock | ollama | none

# Gemini — FREE, no card. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-lite-latest   # lite = faster/cheaper/bigger free quota, fluent Hindi

# Groq — FREE, no card. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# Anthropic. https://console.anthropic.com/
ANTHROPIC_API_KEY=
# NARRATION_MODEL=claude-sonnet-4-6

# Bedrock (optional) — uses the standard AWS credential chain (aws configure / env / role)
# AWS_REGION=us-east-1
# BEDROCK_MODEL=amazon.nova-micro-v1:0

# Ollama (optional, fully local, no key) — run `ollama serve` + `ollama pull llama3.2`
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Optional overrides (sensible defaults live in backend/config.py) ---
# VAYULENS_DB_PATH=data/vayulens.duckdb
# FIRMS_SOURCE=VIIRS_SNPP_NRT
# OPENAQ_BASE_URL=https://api.openaq.org/v3
# NARRATION_TIMEOUT_S=120
